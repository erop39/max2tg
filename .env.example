# Max credentials (DevTools → Application → Local Storage → web.max.ru)
MAX_TOKEN=your___oneme_auth_value
MAX_DEVICE_ID=your___oneme_device_id_value
# (Optional) Max chat IDs to listen, comma-separated. Leave unset to listen to all chats.
# MAX_CHAT_IDS=-123,-456

# Telegram (get token from @BotFather; find your chat_id via @userinfobot)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_CHAT_ID=123456789

# (Optional) SOCKS5 proxy for Telegram (e.g. socks5://user:pass@host:port)
# TG_PROXY=socks5://127.0.0.1:1080

# (Optional) Telegram HTTP timeouts in seconds. Increase if proxy is slow and files are sent multiple times.
# TG_READ_TIMEOUT=30
# TG_WRITE_TIMEOUT=30
# TG_MEDIA_WRITE_TIMEOUT=120

# Debug mode: verbose logs + JSON dump to debug/ (true/false)
DEBUG=false

# Allow replies from Telegram back to Max (true/false)
REPLY_ENABLED=false

# Load plugins from app/plugins/ (true/false, default true)
PLUGINS_ENABLED=true

# Forward only unread messages (skip if already read in Max web/app)
# UNREAD_ONLY=true
# Seconds to wait before check — lets read-mark event arrive if Max is open
# UNREAD_DELAY_SEC=2

# Skip muted chats (same as «без звука» / не беспокоить in Max)
# SKIP_MUTED=true

# Enable buffered digest for muted chats via /muted and inline button
# MUTED_DIGEST_ENABLED=true

# Log directory (default: logs)
# LOG_DIR=logs
